# Copy to .env.local and fill in. .env.local is gitignored — never commit real keys.
#
# This file IS committed. The gitignore rule is `.env*.local`, which covers
# .env.local but NOT this file — the .example suffix puts it outside the pattern.
# Placeholders only, never real values.

# Resend API key for the contact form.
# Get one at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Where contact form submissions are delivered.
CONTACT_TO_EMAIL=you@example.com
